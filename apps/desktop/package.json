{
  "name": "@reading/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.electron.json && vite build",
    "dev": "vite",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint src electron",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@reading/application": "workspace:*",
    "@reading/design-system": "workspace:*",
    "@reading/domain": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "zustand": "^5.0.3"
  }
}
